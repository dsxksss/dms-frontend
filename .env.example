# API 基础地址。留空 = 同源（dev 走 vite proxy，prod 走 nginx 反代）。
# 仅当前端与后端分域部署、且不经反代时才需要填绝对地址（如 https://api.example.com）。
VITE_API_BASE_URL=

# dev proxy 目标（仅 vite.config.ts 在开发期使用）。
VITE_API_PROXY=http://127.0.0.1:8080

# 单租户/私有化部署：设为某租户 slug 后，登录页将隐藏“租户”输入框（普通用户无需填写）。
# SaaS 多租户留空；租户可由邀请链接 ?tenant=acme 携带，或登录后记住上次租户。
VITE_DEFAULT_TENANT=

# SaaS 子域名取租户的后缀（须与后端 auth.tenant_host_suffix 一致）。
# 设为如 dms.app 后，访问 acme.dms.app 登录页自动识别租户 acme 并隐藏输入框（零输入）。
VITE_TENANT_HOST_SUFFIX=

# 登录页是否以 WeMol 账号 SSO 为默认入口。默认开启（对接了 WeMol 的部署）。
# 未配置 WeMol（后端无 [auth.wemol].base_url）的部署设为 off：登录页默认邮箱+密码、
# WeMol 作次选（仍可在登录页切换）。
VITE_WEMOL_SSO=
